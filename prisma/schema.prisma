generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  place     String?
  phone     String
  date      DateTime
  time      String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}
